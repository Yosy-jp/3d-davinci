<!DOCTYPE html>
<html>
<head>
    <title>USB Capture Debug</title>
    <meta charset="utf-8">
</head>
<body style="background: #222; color: white; font-family: sans-serif; text-align: center;">
    <h2>USBデバイス確認ツール</h2>
    
    <div id="deviceList" style="margin-bottom: 20px; border: 1px solid #555; padding: 10px;">
        デバイスを探しています...
    </div>

    <video id="debugVideo" autoplay playsinline style="width: 80%; border: 2px solid white;"></video>
    
    <p>現在のデバイスID: <br><span id="currentId" style="font-size: 12px; color: #aaa;">未選択</span></p>

    <script>
        async function initDebug() {
            const listElement = document.getElementById('deviceList');
            const video = document.getElementById('debugVideo');
            const idDisplay = document.getElementById('currentId');

            try {
                // 最初に一度権限をリクエストしないとデバイス名が取得できません
                await navigator.mediaDevices.getUserMedia({ video: true });

                // デバイス一覧を取得
                const devices = await navigator.mediaDevices.enumerateDevices();
                const videoDevices = devices.filter(device => device.kind === 'videoinput');

                listElement.innerHTML = "<h3>見つかったデバイス:</h3>";
                
                videoDevices.forEach((device, index) => {
                    const btn = document.createElement('button');
                    btn.innerHTML = `${index}: ${device.label || '不明なデバイス'}`;
                    btn.style.margin = "5px";
                    btn.style.padding = "10px";
                    
                    btn.onclick = async () => {
                        // 選択したデバイスで映像を開始
                        const constraints = {
                            video: { deviceId: { exact: device.deviceId } }
                        };
                        const stream = await navigator.mediaDevices.getUserMedia(constraints);
                        video.srcObject = stream;
                        idDisplay.innerText = device.deviceId;
                    };
                    
                    listElement.appendChild(btn);
                });

            } catch (err) {
                listElement.innerHTML = "エラー: " + err.message + "<br>HTTPSで接続しているか確認してください。";
            }
        }

        initDebug();
    </script>
</body>
</html>
